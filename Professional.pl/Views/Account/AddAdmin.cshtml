@using Profissonal.PPL.ModelVM
@model RegisterVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "إضافة مشرف جديد";
}

<div class="animate__animated animate__fadeIn">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <!-- Header with Back Button -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <a asp-action="Admins" class="btn btn-outline-primary rounded-pill px-4">
                    <i class="fa-solid fa-arrow-right me-2"></i> عودة للقائمة
                </a>
                <h4 class="fw-bold mb-0">إنشاء حساب مشرف</h4>
            </div>

            <div class="glass-card bg-white p-5 shadow-sm border-0">
                <div class="text-center mb-5">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fa-solid fa-user-shield display-6"></i>
                    </div>
                    <p class="text-muted mt-2">قم بتعبئة بيانات المشرف الجديد لتمكينه من الدخول للنظام</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger border-0 rounded-4 p-4 mb-4 shadow-sm d-flex align-items-start gap-3">
                        <i class="fa-solid fa-circle-xmark fs-4 mt-1"></i>
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-1">يرجى تصحيح الأخطاء التالية:</h6>
                            @Html.ValidationSummary(false, "", new { @class = "small mb-0 list-unstyled" })
                        </div>
                    </div>
                }

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success border-0 rounded-4 p-3 mb-4 shadow-sm text-center fw-bold">
                        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
                    </div>
                }

                <form asp-action="AddAdmin" asp-controller="Account" method="post" class="premium-form">
                    @Html.AntiForgeryToken()

                    <div class="row g-4">
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="FullName" class="form-control" placeholder="الاسم بالكامل" required />
                                <label asp-for="FullName">الاسم الكامل للمشرف</label>
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="Email" class="form-control" type="email" placeholder="example@domain.com" required />
                                <label asp-for="Email">البريد الإلكتروني (إسم المستخدم)</label>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating position-relative">
                                <input asp-for="Password" class="form-control" type="password"
                                       id="passInput" placeholder="********" required />
                                <label asp-for="Password">كلمة المرور</label>
                                <button type="button" class="toggle-pass"
                                        onclick="toggleField('passInput','eyeIcon1')">
                                    <i class="fa-solid fa-eye" id="eyeIcon1"></i>
                                </button>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating position-relative">
                                <input asp-for="ConfirmPassword" class="form-control" type="password"
                                       id="confirmInput" placeholder="********" required />
                                <label asp-for="ConfirmPassword">تأكيد كلمة المرور</label>
                                <button type="button" class="toggle-pass"
                                        onclick="toggleField('confirmInput','eyeIcon2')">
                                    <i class="fa-solid fa-eye" id="eyeIcon2"></i>
                                </button>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 fw-bold fs-5 shadow-sm">
                                <i class="fa-solid fa-circle-plus me-2"></i> تأكيد إضافة المشرف
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function toggleField(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'fa-solid fa-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'fa-solid fa-eye';
            }
        }
    </script>
}