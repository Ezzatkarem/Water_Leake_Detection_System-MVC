@using Profissonal.PPL.ModelVM
@using Profissonal.PPL.Response
@model Response<List<AdminVM>>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "إدارة المشرفين";
}

<div class="animate__animated animate__fadeIn">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">المشرفين ومدراء النظام</h3>
            <p class="text-muted small mb-0">إدارة صلاحيات الوصول والمسؤولين عن النظام</p>
        </div>
        @if (User.Identity.IsAuthenticated && User.Identity.Name == "admin@leak.com")
        {
            <a asp-action="AddAdmin" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="fa-solid fa-user-plus me-2"></i> إضافة مشرف جديد
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 rounded-4 shadow-sm p-3 mb-4 d-flex align-items-center">
            <i class="fa-solid fa-circle-check fs-4 me-3"></i>
            <div>@TempData["Success"]</div>
        </div>
    }

    @if (Model.Secsses==false)
    {
        <div class="alert alert-warning border-0 rounded-4 shadow-sm p-4">
            <div class="d-flex align-items-center gap-3">
                <i class="fa-solid fa-circle-exclamation fs-2"></i>
                <h5 class="mb-0">@Model.MessageError</h5>
            </div>
        </div>
    }
    else
    {
        <div class="glass-card bg-white p-0 overflow-hidden shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="px-4 py-3" style="width: 80px;">#</th>
                            <th class="py-3">الاسم الكامل</th>
                            <th class="py-3">البريد الإلكتروني</th>
                            <th class="py-3">الدور الوظيفي</th>
                            <th class="px-4 py-3 text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Result.Count; i++)
                        {
                            var admin = Model.Result[i];
                            <tr>
                                <td class="px-4 text-muted fw-bold">@(i + 1)</td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
                                            <i class="fa-solid fa-user-tie"></i>
                                        </div>
                                        <span class="fw-bold">@admin.Name</span>
                                    </div>
                                </td>
                                <td><span class="text-muted">@admin.Email</span></td>
                                <td>
                                    @if (admin.Email == "admin@leak.com")
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill fw-bold border border-danger border-opacity-10">مدير نظام (Super)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-bold border border-primary border-opacity-10">مشرف محتوى</span>
                                    }
                                </td>
                                <td class="px-4 text-center">
                                    @if (User.Identity.IsAuthenticated && User.Identity.Name == "admin@leak.com")
                                    {
                                        if (admin.Email != "admin@leak.com")
                                        {
                                            <form asp-action="DeleteAdmin" method="post" onsubmit="return confirm('حذف هذا المشرف نهائياً؟')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@admin.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 py-1 fw-bold">
                                                    <i class="fa-solid fa-trash-can me-2"></i> حذف
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small italic">غير قابل للحذف</span>
                                        }
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-lock text-muted opacity-50"></i>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>