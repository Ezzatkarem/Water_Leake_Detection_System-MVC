@using Profissonal.PPL.ModelVM
@using Profissonal.PPL.Response
@model Response<LeakRequestVM>

@{
    ViewData["Title"] = "تم استلام طلبك بنجاح";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="glass-card bg-white p-5 text-center animate__animated animate__zoomIn>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success mb-4">
                        @TempData["Success"]
                    </div>
                }

                @if (Model?.Result != null)
                {
                    <div class="mb-4">
                        <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center animate__animated animate__bounceIn animate__delay-1s" style="width: 100px; height: 100px;">
                            <i class="fa-solid fa-check-double display-3"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold text-dark mb-3">تم إرسال طلبك بنجاح!</h2>
                    <p class="text-muted fs-5 mb-5">شكراً لثقتك بنا. فريقنا الفني سيقوم بمراجعة طلبك والتواصل معك خلال 15 دقيقة لتأكيد الموعد.</p>

                    <div class="bg-light rounded-4 p-4 border mb-5 text-start">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-muted fw-bold small">تفاصيل الطلب:</span>
                            <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm">#@Model.Result.Id</span>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <p class="mb-0 text-muted tiny">اسم العميل</p>
                                <p class="fw-bold mb-0">@Model.Result.ClientName</p>
                            </div>
                            <div class="col-6">
                                <p class="mb-0 text-muted tiny">رقم الهاتف</p>
                                <p class="fw-bold mb-0" dir="ltr">@Model.Result.Phone</p>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-3">
                        <a asp-action="GetLeakbyId" asp-controller"" asp-route-id="@Model.Result.Id" class="btn btn-primary rounded-pill py-3 fw-bold fs-5 shadow-sm">
                            <i class="fa-solid fa-magnifying-glass-location me-2"></i> تتبع حالة الطلب الآن
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill py-3 fw-bold">
                            <i class="fa-solid fa-house me-2"></i> العودة للرئيسية
                        </a>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="text-warning mb-4">
                            <i class="fa-solid fa-circle-exclamation fa-4x"></i>
                        </div>
                        <h3 class="fw-bold mb-3">عذراً، الطلب غير موجود</h3>
                        <p class="text-muted mb-4">@(Model?.MessageError ?? "لم نتمكن من العثور على الطلب")</p>
                        <a asp-action="Index" class="btn btn-primary rounded-pill px-5 py-2">
                            العودة للرئيسية
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .tiny {
        font-size: 0.75rem;
    }
</style>