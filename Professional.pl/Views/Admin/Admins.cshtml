@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "إدارة المشرفين";
}

<div class="animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">إدارة المشرفين</h3>
            <p class="text-muted small mb-0">إدارة حسابات المسؤولين وصلاحيات الوصول</p>
        </div>
        <button class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-user-plus me-2"></i> إضافة مشرف جديد
        </button>
    </div>

    <div class="glass-card bg-white p-5 text-center my-5">
        <div class="mb-4">
            <i class="fa-solid fa-user-shield display-1 text-muted opacity-25"></i>
        </div>
        <h3 class="fw-bold mb-3">هذه الصفحة قيد التطوير</h3>
        <p class="text-muted mb-4 mx-auto" style="max-width: 500px;">
            ستتمكن قريباً من إدارة فريق المشرفين وتخصيص الصلاحيات لكل فرد.
        </p>
    </div>
</div>
