@using Profissonal.PPL.ModelVM
@using Profissonal.PPL.Response
@model Response<LeakRequestVM>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "تفاصيل الطلب";
    var request = Model.Result;
}

<style>
    .timeline-wrapper {
        position: relative;
        padding: 40px 0;
    }

    .timeline-line {
        position: absolute;
        top: 50%;
        left: 10%;
        right: 10%;
        height: 4px;
        background: #e2e8f0;
        transform: translateY(-50%);
        z-index: 1;
    }

    .timeline-progress {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        background: var(--primary);
        transition: width 1s ease;
    }

    .timeline-steps {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
    }

    .step-item {
        text-align: center;
        width: 120px;
    }

    .step-icon {
        width: 50px;
        height: 50px;
        background: white;
        border: 4px solid #e2e8f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 1.2rem;
        color: #94a3b8;
        transition: var(--transition-base);
    }

    .step-item.active .step-icon {
        border-color: var(--primary);
        color: var(--primary);
        box-shadow: 0 0 15px rgba(0, 119, 182, 0.2);
    }

    .step-item.completed .step-icon {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }

    .step-label {
        font-weight: 700;
        font-size: 0.9rem;
        color: #64748b;
    }

    .step-item.active .step-label { color: var(--primary); }

    @@media (max-width: 768px) {
        .timeline-line {
            left: 25px;
            right: auto;
            top: 0;
            bottom: 0;
            width: 4px;
            height: 100%;
            transform: none;
        }
        .timeline-steps {
            flex-direction: column;
            gap: 30px;
            align-items: flex-start;
            padding-left: 0;
        }
        .step-item {
            width: 100%;
            display: flex;
            align-items: center;
            text-align: right;
            gap: 20px;
        }
        .step-icon {
            margin: 0;
        }
    }

    .info-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        height: 100%;
        border: 1px solid rgba(0,0,0,0.05);
    }
</style>

<div class="animate__animated animate__fadeIn">
    <!-- Header with Back Button -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-primary rounded-pill px-4">
            <i class="fa-solid fa-arrow-right me-2"></i> عودة للطلبات
        </a>
        <div class="text-end">
            <p class="mb-0 text-muted small">رقم المرجع</p>
            <h4 class="fw-bold mb-0 text-primary">#@request.Id</h4>
        </div>
    </div>

    <!-- Timeline Progress -->
    <div class="glass-card bg-white p-5 mb-4">
        <div class="timeline-wrapper">
            <div class="timeline-line">
                @{
                    var progressWidth = "0%";
                    if (request.Status == "InProgress") progressWidth = "50%";
                    if (request.Status == "Done" || request.Status == "Completed") progressWidth = "100%";
                }
                <div class="timeline-progress" style="width: @progressWidth"></div>
            </div>
            <div class="timeline-steps">
                <div class="step-item @(request.Status == "Pending" ? "active" : "completed")">
                    <div class="step-icon"><i class="fa-solid fa-clock"></i></div>
                    <div class="step-label">قيد الانتظار</div>
                </div>
                <div class="step-item @(request.Status == "InProgress" ? "active" : (request.Status == "Done" || request.Status == "Completed" ? "completed" : ""))">
                    <div class="step-icon"><i class="fa-solid fa-spinner @(request.Status == "InProgress" ? "fa-spin" : "")"></i></div>
                    <div class="step-label">جاري العمل</div>
                </div>
                <div class="step-item @(request.Status == "Done" || request.Status == "Completed" ? "active completed" : "")">
                    <div class="step-icon"><i class="fa-solid fa-check-double"></i></div>
                    <div class="step-label">تم الإنجاز</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Client Info -->
        <div class="col-lg-8">
            <div class="info-card">
                <h5 class="fw-bold mb-4 border-bottom pb-3"><i class="fa-solid fa-user-tag text-primary me-2"></i> بيانات الطلب</h5>
                <div class="row g-4">
                    <div class="col-sm-6">
                        <label class="text-muted small d-block mb-1">اسم العميل</label>
                        <p class="fw-bold fs-5">@request.ClientName</p>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small d-block mb-1">رقم الهاتف</label>
                        <p class="fw-bold fs-5" dir="ltr">@request.Phone</p>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small d-block mb-1">نوع المشكلة</label>
                        <p class="fw-bold text-primary">@request.ProplemType</p>
                    </div>
                    <div class="col-sm-6">
                        <label class="text-muted small d-block mb-1">تاريخ الطلب</label>
                        <p class="fw-bold">@request.CreatedAt.ToString("dd MMMM yyyy - hh:mm tt")</p>
                    </div>
                    <div class="col-12">
                        <label class="text-muted small d-block mb-1">العنوان بالتفصيل</label>
                        <p class="fw-bold"><i class="fa-solid fa-location-dot text-danger me-1"></i> @request.Address</p>
                    </div>
                    <div class="col-12">
                        <label class="text-muted small d-block mb-1">وصف العميل للمشكلة</label>
                        <div class="p-3 bg-light rounded-3 border">
                            @(string.IsNullOrEmpty(request.Description) ? "لا يوجد وصف إضافي" : request.Description)
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status Actions -->
        <div class="col-lg-4">
            <div class="info-card">
                <h5 class="fw-bold mb-4 border-bottom pb-3"><i class="fa-solid fa-sliders text-primary me-2"></i> تحديث الحالة</h5>
                
                <form asp-action="UpdateStatus" asp-controller="Admin" method="post" class="d-grid gap-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@request.Id" />
                    
                    <button type="submit" name="status" value="Pending" 
                            class="btn btn-outline-warning rounded-pill py-3 fw-bold @(request.Status == "Pending" ? "active d-none" : "")">
                        <i class="fa-solid fa-clock me-2"></i> نقل لقيد الانتظار
                    </button>
                    
                    <button type="submit" name="status" value="InProgress" 
                            class="btn btn-outline-primary rounded-pill py-3 fw-bold @(request.Status == "InProgress" ? "active d-none" : "")">
                        <i class="fa-solid fa-spinner fa-spin me-2"></i> بدء العمل الفعلي
                    </button>
                    
                    <button type="submit" name="status" value="Done" 
                            class="btn btn-success rounded-pill py-3 fw-bold @(request.Status == "Done" || request.Status == "Completed" ? "active d-none" : "")">
                        <i class="fa-solid fa-check-double me-2"></i> تم الانتهاء والتحصيل
                    </button>
                    
                    <div class="mt-4 p-3 bg-primary bg-opacity-10 rounded-3 text-center">
                        <p class="text-primary small mb-0 fw-bold">
                            تحديث الحالة يرسل تنبيهاً تلقائياً في سجلات التتبع الخاصة بالعميل.
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>