@using Profissonal.PPL.ModelVM
@model VedioVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "إضافة فيديو جديد";
}

<div class="animate__animated animate__fadeIn">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header with Back Button -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <a asp-action="Vedios" class="btn btn-outline-primary rounded-pill px-4">
                    <i class="fa-solid fa-arrow-right me-2"></i> عودة لقائمة الفيديوهات
                </a>
                <h4 class="fw-bold mb-0">إضافة فيديو جديد</h4>
            </div>

            <div class="glass-card bg-white p-5 shadow-sm border-0">
                <div class="text-center mb-5">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fa-brands fa-youtube display-6"></i>
                    </div>
                    <p class="text-muted mt-2">أضف روابط فيديوهات يوتيوب لتوثيق عمليات الكشف والنجاحات</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger border-0 rounded-4 p-4 mb-4 shadow-sm d-flex align-items-start gap-3">
                        <i class="fa-solid fa-circle-xmark fs-4 mt-1"></i>
                        <div class="flex-grow-1">
                            @Html.ValidationSummary(false, "", new { @class = "small mb-0 list-unstyled" })
                        </div>
                    </div>
                }

                <form asp-action="AddVedio" asp-controller="Admin" method="post" id="video-form" class="premium-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="YoutubeVideoId" id="YoutubeVideoId" />

                    <div class="row g-4">
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="Dsecription" class="form-control" placeholder="وصف الفيديو" required />
                                <label asp-for="Dsecription">عنوان/وصف الفيديو المختصر</label>
                                <span asp-validation-for="Dsecription" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="YoutubeUrl" class="form-control" id="YoutubeUrl" placeholder="رابط اليوتيوب" required oninput="previewVideo()" />
                                <label asp-for="YoutubeUrl">رابط فيديو اليوتيوب (URL)</label>
                                <span asp-validation-for="YoutubeUrl" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Video Preview Box -->
                        <div class="col-12" id="preview-box" style="display: none;">
                            <div class="p-4 bg-light rounded-4 border">
                                <h6 class="fw-bold mb-3"><i class="fa-solid fa-eye me-2 text-primary"></i> معاينة الفيديو:</h6>
                                <div class="ratio ratio-16x9 rounded-3 overflow-hidden shadow-sm">
                                    <iframe id="video-iframe" src="" allowfullscreen></iframe>
                                </div>
                                <div class="mt-3 text-center">
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 border border-success border-opacity-10">تم التعرف على الفيديو بنجاح</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" id="submit-btn" class="btn btn-primary w-100 rounded-pill py-3 fw-bold fs-5 shadow-sm" disabled>
                                <i class="fa-solid fa-circle-plus me-2"></i> إضافة الفيديو للقائمة
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function extractVideoId(url) {
            var regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
            var match = url.match(regExp);
            return (match && match[2].length == 11) ? match[2] : null;
        }

        function previewVideo() {
            var url = document.getElementById('YoutubeUrl').value;
            var videoId = extractVideoId(url);
            var previewBox = document.getElementById('preview-box');
            var iframe = document.getElementById('video-iframe');
            var submitBtn = document.getElementById('submit-btn');
            var idInput = document.getElementById('YoutubeVideoId');

            if (videoId) {
                iframe.src = "https://www.youtube.com/embed/" + videoId;
                previewBox.style.display = 'block';
                idInput.value = videoId;
                submitBtn.disabled = false;
            } else {
                previewBox.style.display = 'none';
                iframe.src = "";
                idInput.value = "";
                submitBtn.disabled = true;
            }
        }
        
        // Initial check on load
        window.onload = previewVideo;
    </script>
}