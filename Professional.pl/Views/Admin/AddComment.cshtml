@using Profissonal.PPL.ModelVM
@model CommentVM

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "إضافة تعليق جديد";
}

<div class="animate__animated animate__fadeIn">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Header with Back Button -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <a asp-action="Comments" class="btn btn-outline-primary rounded-pill px-4">
                    <i class="fa-solid fa-arrow-right me-2"></i> عودة لقائمة التعليقات
                </a>
                <h4 class="fw-bold mb-0">إضافة تعليق جديد</h4>
            </div>

            <div class="glass-card bg-white p-5 shadow-sm border-0">
                <div class="text-center mb-5">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <i class="fa-solid fa-comment-medical display-6"></i>
                    </div>
                    <p class="text-muted mt-2">أضف تعليقات إيجابية من عملائك لعرضها في قسم "ماذا يقول عملاؤنا"</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger border-0 rounded-4 p-4 mb-4 shadow-sm d-flex align-items-start gap-3">
                        <i class="fa-solid fa-circle-xmark fs-4 mt-1"></i>
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-1">يرجى تصحيح الأخطاء التالية:</h6>
                            @Html.ValidationSummary(false, "", new { @class = "small mb-0 list-unstyled" })
                        </div>
                    </div>
                }

                <form asp-action="AddComment" asp-controller="Admin" method="post" class="premium-form">
                    @Html.AntiForgeryToken()

                    <div class="row g-4">
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="Author" class="form-control" placeholder="اسم صاحب التعليق" required />
                                <label asp-for="Author">اسم العميل (صاحب التعليق)</label>
                                <span asp-validation-for="Author" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-floating">
                                <textarea asp-for="Content" class="form-control" style="height: 120px" placeholder="التعليق بالعربي" required></textarea>
                                <label asp-for="Content">التعليق باللغة العربية</label>
                                <span asp-validation-for="Content" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-floating">
                                <textarea asp-for="ContentEn" class="form-control" style="height: 120px" placeholder="التعليق بالإنجليزي"></textarea>
                                <label asp-for="ContentEn">التعليق باللغة الإنجليزية (اختياري)</label>
                                <span asp-validation-for="ContentEn" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 fw-bold fs-5 shadow-sm">
                                <i class="fa-solid fa-circle-plus me-2"></i> نشر التعليق في الموقع
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>